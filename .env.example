# ============================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ ДЛЯ VERCEL (mono-pay)
# Скопируйте этот файл в .env для локальной разработки
# В Vercel добавьте через: Settings → Environment Variables
# ============================================================

# ─── SHOPIFY OAuth App (из Dev Dashboard) ────────────────────
# Client ID вашего приложения (из Shopify Partners / Dev Dashboard)
SHOPIFY_CLIENT_ID=your_client_id_here

# Client Secret вашего приложения (из Shopify Partners / Dev Dashboard)
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# ─── SHOPIFY Access Token (получается ПОСЛЕ OAuth-флоу) ──────
# Постоянный токен доступа к Admin API.
# Получить: откройте https://your-project.vercel.app/api/auth?shop=your-store.myshopify.com
# Скопируйте токен со страницы и вставьте сюда.
SHOPIFY_ACCESS_TOKEN=

# ─── SHOPIFY Магазин ─────────────────────────────────────────
# Домен вашего магазина (без https://, без слэша в конце)
# Пример: my-store.myshopify.com
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# URL вашего магазина (для CORS и редиректа после оплаты)
SHOPIFY_STORE_URL=https://your-store.myshopify.com

# URL для редиректа покупателя ПОСЛЕ успешной оплаты в Monobank
SHOPIFY_REDIRECT_URL=https://your-store.myshopify.com/pages/thank-you

# Версия Shopify Admin API (рекомендуется оставить как есть)
SHOPIFY_API_VERSION=2025-01

# ─── MONOBANK ─────────────────────────────────────────────────
# Токен мерчанта Monobank
# Получить: https://web.monobank.ua → Налаштування → API → Токен для мерчантів
MONOBANK_API_TOKEN=your_monobank_merchant_token_here

# Срок действия инвойса в секундах (по умолчанию 86400 = 24 часа)
MONOBANK_INVOICE_VALIDITY_SEC=86400

# ─── VERCEL / ПРИЛОЖЕНИЕ ──────────────────────────────────────
# Публичный URL вашего Vercel-деплоя (используется для webHookUrl Monobank и OAuth redirect)
# Пример: https://mono-pay-xxx.vercel.app
APP_URL=https://your-project.vercel.app

# Разрешённые CORS-источники (через запятую, если несколько доменов)
ALLOWED_ORIGINS=https://your-store.myshopify.com
